# Server-only configuration. Never copy these values to frontend/.env.
PORT=5000
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:5000
# Set to 1 only when your deployment host uses one trusted reverse proxy.
TRUST_PROXY=0

# Supabase server credentials
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Runtime AI provider
QWEN_API_KEY=
QWEN_ENDPOINT=
QWEN_MODEL=qwen-max

# Operations
ORDER_DELAY_MINUTES=15

# Required only when running backend/fix-vendor-link.js.
# This is a dedicated public demo email, not a personal account.
DEMO_VENDOR_EMAIL=warungmurni@gmail.com
